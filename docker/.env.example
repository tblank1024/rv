# Copy this file to .env and fill in real values
# docker-compose reads .env automatically from the same directory

# MQTT broker credentials — every service authenticates with these.
# Generate the matching hash file with:
#   docker exec mqtt mosquitto_passwd -c -b /mosquitto/config/mosquitto.passwd <user> <pass>
MQTT_USER=rv
MQTT_PASS=changeme

# Kasa HS300 power strip
KASA_IP=10.0.x.x
KASA_USERNAME=your@email.com
KASA_PASSWORD=yourpassword

# RASPAp (used only with: docker compose --profile raspap up -d)
RASPAP_SSID=YourSSID
RASPAP_SSID_PASS=changeme
RASPAP_WEBGUI_USER=admin
RASPAP_WEBGUI_PASS=changeme

# rvc2mqtt build context (fork of linuxkidd/rvc-monitor-py); defaults to
# ../../../linuxkidd/rvc-monitor-py. Run ./setup-rvc-monitor.sh to clone/verify.
#RVC_MONITOR_DIR=
